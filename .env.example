# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=
VITE_HF_API_TOKEN=

# HF_API_TOKEN: Optional for using Hugging Face models as alternative.
# Use your own token from https://huggingface.co/settings/tokens
VITE_HF_API_TOKEN=
